# ---- Postgres ----
POSTGRES_DB=ams
POSTGRES_USER=ams
POSTGRES_PASSWORD=ams_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django ----
DJANGO_SECRET_KEY=change-me-in-production-super-secret-key
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0

# ---- Email (outreach campaigns) ----
# Dev default = console backend (emails printed to backend logs, no keys needed).
# For production with SendGrid, uncomment and fill:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=ams@institute.edu

# ---- Seed admin (created on first boot) ----
DJANGO_SUPERUSER_EMAIL=admin@institute.edu
DJANGO_SUPERUSER_PASSWORD=admin12345

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000/api
